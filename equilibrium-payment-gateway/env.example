# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Equilibrium Payment Gateway"
APP_VERSION="1.0.0"
ENVIRONMENT=development
DEBUG=true

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=mude-isso-em-producao-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Protege a rota POST /auth/setup (cria o primeiro admin). Use: openssl rand -hex 24
ADMIN_SETUP_KEY=mude-isso-em-producao

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://equilibrium_user:equilibrium_pass@localhost:5432/equilibrium_payments

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ─── Payment Providers ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAGARME_API_KEY=ak_test_...

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASSWORD=sua-senha-de-app
